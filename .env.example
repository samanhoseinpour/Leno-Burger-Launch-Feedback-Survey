# Copy this file to .env and fill in the values. (.env is git-ignored.)

# --- Database (Postgres / Neon) ---
# The app uses Postgres in every environment — Vercel serverless has no
# persistent disk for SQLite. Locally, use your Neon connection string (a Neon
# "dev" branch is ideal so you never touch production data):
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
# On Vercel, the Neon Marketplace integration injects DATABASE_URL automatically.

# --- Admin ---
# Password that gates the /admin dashboard. Use a strong value in production.
ADMIN_PASSWORD="change-me"
