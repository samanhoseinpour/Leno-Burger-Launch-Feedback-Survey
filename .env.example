# Copy this file to .env and fill in the values. (.env is git-ignored.)

# --- Database ---
# Local development uses SQLite; this default works out of the box:
DATABASE_URL="file:./dev.db"
# For production, switch the datasource `provider` in prisma/schema.prisma from
# "sqlite" to "postgresql" and point DATABASE_URL at your Postgres instance, e.g.:
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# --- Admin ---
# Password that gates the /admin dashboard. Use a strong value in production.
ADMIN_PASSWORD="change-me"
